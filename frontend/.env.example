NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-specdec

# Custom SMTP (Optional - If set, the app will use this instead of default Supabase mail)
# Note: For Supabase Auth specifically, it is recommended to set these in the Supabase Dashboard.
# For StackBlitz/WebContainers: Use RESEND_API_KEY instead of SMTP to bypass port blocks.
RESEND_API_KEY=your_resend_api_key
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_username
SMTP_PASS=your_password
SMTP_SENDER_EMAIL=support@yourdomain.com
SMTP_SENDER_NAME=PDPL Compliance
